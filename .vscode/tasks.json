{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile",
            "command": "python3", // Could be any other shell command
            "args": [
                "compile.py",
                "dev"
            ],
            "type": "shell"
        },
        {
            "label": "build unit tests",
            "command": "make",
            "args": [
                "unit_tests"
            ],
            "type": "shell",
            "group": "build"
        },
        {
            "label": "build unit tests (debug)",
            "command": "make",
            "args": [
                "debug"
            ],
            "type": "shell",
            "group": "build"
        }
    ]
}